{
	"npc_1":{
		"tree":[
			{
				"branch_id": "npc_1_1", 
				"dialogues":[
					{
						"state":"start",
						"trust_required":0,
						"speaker":"...",
						"text":"Um... hello?",
						"options": {
							"Who are you?":"talk_first",
							"leave":"exit_no_quest_zero_trust",
						}
					},
					{
						"state":"start_zero_trust_1",
						"trust_required":0,
						"text":"Oh, it's you again...",
						"options":{
							"I have a question":"talk_menu_zero_trust",
							"leave":"exit_no_quest_zero_trust"
						}
					},
					{
						"state":"talk_first",
						"trust_required":0,
						"text":"M-my name is Yaegashi. I study here... I mean, used to study...",
						"options": {
							"Tell me something":"talk_menu_zero_trust",
							"leave":"exit_no_quest_zero_trust"
						}
					},
					{
						"state":"talk_menu_zero_trust",
						"trust_required":0,
						"text":"Sure, What do you want to know?",
						"options":{
							"Why are you here?":"talk_why_here_1",
							"Can I help?":"give_quests",
							"leave":"exit_interrupt_zero_trust"
						}
					},
					{
						"state":"talk_why_here_1",
						"trust_required":0,
						"text":"I got here, because me and my friends tried to summon a demon. It went as we wanted it to... sadly",
						"options":{
							"next": "talk_why_here_2",
							"leave": "exit_interrupt_zero_trust"
						}
					},
					{
						"state":"talk_why_here_2",
						"trust_required":0,
						"text":"Then a terrifying scream and... everything went dark. We ran away, I heard screams of my friends, but helping them... would be a suicide.",
						"options":{
							"next":"talk_why_here_3",
							"leave":"exit_interrupt_zero_trust"
						}
					},
					{
						"state":"talk_why_here_3",
						"trust_required":0,
						"text":"I don't know if my friends are alive... I'm cold... Why did we even agree to do that...?",
						"options":{
							"Can I help you?":"give_quests",
							"leave":"exit_no_quest_zero_trust"
						}
					},
					{
						"state":"in_progress",
						"text":"ERROR! I SHOULDN'T SAY THIS",
						"options": {
							"go back":"start",
							"Take quest":"give_quests",
							"leave":"exit",
						}
					},
						{
						"state":"give_quests",
						"trust_required":0,
						"text":"I am running low on food... Could you check on vending machines... or cafeteria at least? But be careful! Loud noises attract monsters!",
						"options": {
							"I'll think about it":"exit_no_quest_zero_trust",
							"Sure":"exit_quest_accept",
						}
					},
						{
						"state":"end",
						"trust_required":0,
						"text":"Thank you for bringing me an item!",
						"options": {
							"leave":"exit",
						}
					},
						{
						"state":"exit",
						"trust_required":0,
						"text":"ok",
						"options":{}
						},
					{
						"state":"exit_quest_accept",
						"trust_required":0,
						"text":"Thanks. It's kind of you",
						"options": {
							"leave":"exit"
						}
					},
					{
						"state":"exit_interrupt_zero_trust",
						"text":"Wha-? D-did I say something wrong?",
						"options":{
							"leave":"exit"
						}
					},
					{
						"state":"exit_no_quest_zero_trust",
						"text":"Oh... okay. Bye",
						"options":{
							"leave":"exit"
						}
					}
				]
			},
			{
				"branch_id": "npc_1_2", 
				"dialogues":[
					{
						"state":"start_low_trust_1",
						"trust_required":2,
						"text":"Thank you! I didn't think you'll actually find food for me!",
						"options":{
							"next":"start_low_trust_2",
							"leave":"exit_interrupt_low_trust"
						}
					},
					{
						"state":"start_low_trust_2",
						"trust_required":2,
						"text":"Now I won't starve to death in here, haha...",
						"options":{
							"Yaegashi, tell me...":"talk_menu_low_trust",
							"leave":"exit_no_quest_low_trust"
						}
					},
					{
						"state":"start_low_trust_return_1",
						"trust_required":2,
						"text":"Hello again!",
						"options":{
							"About yourself":"about_self_1",
							"Why summon demons?":"why_summon_1",
							"Need something else?":"give_quest_2",
							"Nevermind":"exit_no_quest_low_trust"
						}
					},
					{
						"state":"talk_menu_low_trust",
						"trust_required":2,
						"text":"Yes?",
						"options":{
							"About yourself":"about_self_1",
							"Why summon demons?":"why_summon_1",
							"Need something else?":"give_quest_2",
							"Nevermind":"exit_no_quest_low_trust"
						}
					},
					{
						"state":"about_self_1",
						"text":"As you know, I'm Yaegashi. Before the incident, I was studying in this highschool, senior year.",
						"options":{
							"Next":"about_self_2",
							"Nevermind":"exit_interrupt_low_trust"
						}
					},
					{
						"state":"about_self_2",
						"text":"Now... I'm just trying to survive in this cursed place. Monsters are everywhere. It's one of only few safe places in school, I managed to find.",
						"options":{
							"Next":"about_self_3",
							"Nevermind":"exit_interrupt_low_trust"
						}
					},
					{
						"state":"about_self_3",
						"text":"It's been almost a week since the... summoning. I was buying food in vending machines, but my wallet isn't infinite... I just want to go home...",
						"options":{
							"Can I help?":"give_quest_2",
							"And what about...":"talk_menu_low_trust",
							"Gotta go":"exit_no_quest_low_trust"
						}
					},
					{
						"state":"why_summon_1",
						"text":"I... needed a distraction. Tests, teachers and parents got me fed up... I just wanted to do something out of ordinary.",
						"options":{
							"Next":"why_summon_2",
							"Nevermind":"exit_interrupt_low_trust"
						}
					},
					{
						"state":"why_summon_2",
						"text":"Then, suddenly I overheard my classmates talk about summoning a demon at school. This set a sparcle in my heart, so I went with them.",
						"options":{
							"Yaegashi...":"talk_menu_low_trust",
							"Others?":"talk_others_1",
							"Gotta go":"exit_no_quest_low_trust"
						}
					},
					{
						"state":"talk_others_1",
						"text":"Ah, yes. There were five of us. I... don't know if they are still alive at this point. I wish they also survived somehow.",
						"options":{
							"Who exactly?":"talk_others_2",
							"Can I help you?":"give_quest_2",
							"Gotta go":"exit_no_quest_low_trust"
						}
					},
					{
						"state":"talk_others_2",
						"text":"Except me, there were Inoue, Kaoru, Yuuki and Hiromu. I hope all of them made it through, but... Kaoru...",
						"options":{
							"Next":"talk_others_3",
							"Gotta go":"exit_interrupt_low_trust"
						}
					},
					{
						"state":"talk_others_3",
						"text":"He has a weak psyche. I don't know why he agreed to come with us. If monsters didn't catch him, he might have... done bad things to himself by now...",
						"options":{
							"Tell me...":"talk_menu_low_trust",
							"Can I help you?":"give_quest_2",
							"Gotta go":"exit_no_quest_low_trust"
						}
					},
					{
						"state":"exit_no_quest_low_trust",
						"text":"Ah, sure...",
						"options":{
							"leave":"exit"
						}
					},
					{
						"state":"give_quest_2",
						"text":"I thought about it and... I am completely defenceless. If a demon runs in here, I am as good as dead... Could you find some weapon for me? You can check PE storeroom for something.",
						"options":{
							"I'll think about that":"exit_no_quest_low_trust",
							"Sure":"exit_quest_accept"
						}
					},
					{
						"state":"exit_quest_accept",
						"text":"Oh, you're a lifesaver! Maybe I will stand a chance against those creatures...",
						"options":{
							"leave":"exit"
						}
					},
					{
						"state":"exit_interrupt_low_trust",
						"text":"Oh...",
						"options":{
							"leave":"exit"
						}
					}
					]
			},
			{
				"branch_id": "npc_1_3", 
				"dialogues":[
					{
						"state":"start_mid_trust_1",
						"trust_required":4,
						"text":"Oh, God! Thank you...",
						"options":{
							"Next":"start_mid_trust_2",
							"Whatever":"exit_interrupt_mid_trust_nameless"
						}
					},
					{
						"state":"start_mid_trust_return_1_nameless",
						"trust_required":4,
						"text":"Hello uh... traveller?. Sorry, I still don't know your name.",
						"options":{
							"Tell name":"about_myself_1",
							"Don't tell":"penalty_option_name"
						}
					},
					{
						"state":"start_mid_trust_return_1_name",
						"trust_required":4,
						"text":"Hi, Kain! Glad you're still alive.",
						"options":{
							"Do you need something?":"give_quest_3",
							"Want to know about me?":"about_myself_menu_return",
							"Nevermind":"exit_no_quest_mid_trust"
						}
					},
					{
						"state":"exit_interrupt_mid_trust_nameless",
						"text":"Ah, wait! I don't even know your name!",
						"options":{
							"Tell name":"leaving_tell_name",
							"leave":"exit"
						}
					},
					{
						"state":"start_mid_trust_2",
						"text":"Sorry, you did so much for me already and I still don't know your name...",
						"options":{
							"Tell name":"about_myself_1",
							"Don't tell":"penalty_option_name"
						}
					},
					{
						"state":"about_myself_1",
						"text":"So, Kain it is... That's an uncommon name. Well, what a dumb statement, isn't it? You are clearly not from here.",
						"options":{
							"Next":"about_myself_menu",
							"Yeah, bye":"exit_no_quest_mid_trust"
						}
					},
					{
						"state":"penalty_option_name",
						"text":"Oh... Sorry for asking.",
						"options":{
							"leave":"exit"
						}
					},
					{
						"state":"about_myself_menu",
						"text":"I mean... you're somewhere from the west, right? And your attire. People don't dress like that anymore. Who are you really, Kain?",
						"options":{
							"My job":"about_job_1",
							"My world":"about_world_1",
							"My past":"penalty_option_past",
							"You shouldn't know":"shouldnt_know"
						}
					},
					{
						"state":"about_myself_menu_return",
						"text":"Yes, I would like to know more about you. Mind telling me something else?",
						"options":{
							"My job":"about_job_1",
							"My world":"about_world_1",
							"My past":"penalty_option_past",
							"You shouldn't know":"shouldnt_know_2_minus_trust"
						}
					},
					{
						"state":"shouldnt_know_2_minus_trust",
						"text":"Well, don't tell me anything then, if you say I shouldn't know.",
						"options":{
							"Do you need something":"",
							"Bye":"exit_interrupt_mid_trust"
						}
					},
					{
						"state":"shouldnt_know",
						"text":"...Maybe you're right. In this cursed world, there definitely are things I don't have to know about.",
						"options":{
							"Tell me":"talk_menu_mid_trust",
							"That's for sure. Bye":"exit_no_quest_mid_trust"
						}
					},
					{
						"state":"about_job_1",
						"speaker":"Kain",
						"text":"... I am a soldier. I fight in laws of the New Inquisition. My job is to eliminate every supernatural phenomenon identified as a threat.",
						"options":{
							"Next":"about_job_2",
							"Sorry, Gotta go":"exit_interrupt_mid_trust"
						}
					},
					{
						"state":"about_job_2",
						"text":"Oh, that's so cool! So, you're like a... Demon hunter?",
						"options":{
							"Next":"about_job_3",
							"Sorry, Gotta go":"exit_interrupt_mid_trust"
						}
					},
					{
						"state":"about_job_3",
						"speaker":"Kain",
						"text":"That's a big exaggeration. Demons are too powerful to deal with alone. Specialized squads are needed to just heavily damage those bastards... There are weaker types of unholy creatures, like the possessed or different abominations. Those are best known and most common to encounter.",
						"options":{
							"Want to know more?":"about_myself_menu_return",
							"Need something else?":"give_quest_3",
							
						}
					},
					{
						"state":"about_world_1",
						"speaker":"Kain",
						"text":"My world... when I entered this place, it was spring of 1869. Almost 70 years have passed since the Punishment day.",
						"options":{
							"Next":"about_world_2",
							"Sorry, Gotta go":"exit_interrupt_mid_trust"
						}
					},
					{
						"state":"about_world_2",
						"text":"Wow! So, you're from the past!",
						"options":{
							"Next":"about_world_3",
							"Sorry, Gotta go":"exit_interrupt_mid_trust"
						}
					},
					{
						"state":"about_world_3",
						"text":"However, looking at what is happening here... I am not surprised.",
						"options":{
							"Next":"about_world_4",
							"Sorry, Gotta go":"exit_interrupt_mid_trust"
						}
					},
					{
						"state":"about_world_4",
						"text":"So, what's the punishment day anyway?. What's happening in your world?",
						"options":{
							"Next":"about_world_5",
							"Sorry, Gotta go":"exit_interrupt_mid_trust"
						}
					},
					{
						"state":"about_world_5",
						"speaker":"Kain",
						"text":"After a French revolution in 1789, creatures from the depths of hell filled the surface and caused a genocide on human race... Only after around 50 years we were able to fight them back and began reclaiming occupied lands.",
						"options":{
							"Want to know something else?":"about_myself_menu_return",
							"Sorry, Gotta go":"exit_interrupt_mid_trust"
						}
					},
					{
						"state":"talk_menu_mid_trust",
						"text":"Hm?",
						"options":{
							"Need something else?":"give_quest_3",
							"Want to know about me?":"about_myself_menu_return",
							"Nevermind":"exit_no_quest_mid_trust"
						}
					},
					{
						"state":"penalty_option_past",
						"speaker":"Kain",
						"text":"Before I became a soldier, I was a member of a criminal group. Our actions consisted of robberies, assaults, kidnappings and sabotage. This is where I learned how to fight and kill.",
						"options":{
							"Next":"about_past_minus_trust_2",
							"leave":"exit_minus_trust"
						}
					},
					{
						"state":"about_past_minus_trust_2",
						"text":"...",
						"options":{
							"Next":"about_past_minus_trust_3",
							"leave":"exit_minus_trust"
						}
					},
					{
						"state":"about_past_minus_trust_3",
						"text":"What an experience... to talk to a criminal.",
						"options":{
							"Next":"about_past_minus_trust_4",
							"leave":"exit_minus_trust"
						}
					},
					{
						"state":"about_past_minus_trust_4",
						"speaker":"Kain",
						"text":"... I had a choice. To rot in prison for the rest of my life or join the forces of the Inquisition. I picked the second option trying to atone for my... sins.",
						"options":{
							"Next":"about_past_minus_trust_5",
							"leave":"exit_minus_trust"
						}
					},
					{
						"state":"about_past_minus_trust_5",
						"text":"... At least you try to change... or something. And you helped me a lot. Just... don't hurt me, please.",
						"options":{
							"I won't":"exit_minus_trust",
							"leave":"exit_minus_trust_scared"
						}
					},
					{
						"state":"exit_minus_trust_scared",
						"text":"...",
						"options":{
							"leave":"exit"
						}
					},
					{
						"state":"exit_minus_trust",
						"text":"... See you.",
						"options":{
							"leave":"exit"
						}
					},
					{
						"state":"give_quest_3",
						"text":"My lamp is running out of battery. Could you please bring me spare ones? You can find it in Computer room. There's no electricity in school, I would probably become insane, sitting here in complete darkness.",
						"options":{
							"I'll think about it":"exit_no_quest_mid_trust",
							"Sure":"exit_quest_accept"
						}
					},
					{
						"state":"exit_no_quest_mid_trust",
						"text":"Alright... Keep yourself safe.",
						"options":{
							"leave":"exit"
						}
					},
					{
						"state":"exit_interrupt_mid_trust",
						"text":"...bye, Kain.",
						"options":{
							"leave":"exit"
						}
					},
					{
						"state":"exit_quest_accept",
						"text":"Kain, I don't know what would I do without you. Thanks",
						"options":{
							"leave":"exit"
						}
					},
					{
						"state":"leaving_tell_name",
						"text":"Oh. Goodbye then, Kain.",
						"options":{
							"leave":"exit"
						}
					}
				]
			},
