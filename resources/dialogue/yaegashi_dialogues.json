				]
			},
			{
				"branch_id": "npc_1_default", 
				"dialogues":[
					{
						"state":"mid_trust_penalty",
						"trust_required":3,
						"text":"You're still alive, Kain. That's good.",
						"options":{
							"How are you?":"talk_penalty",
							"leave":"exit"
						}
					},
					{
						"state":"talk_penalty",
						"text":"Trying not to go insane here... Sounds from outside are frightening.",
						"options":{
							"Need something?":"idk_penalty",
							"leave":"exit"
						}
					},
					{
						"state":"idk_penalty",
						"text":"I don't know. Maybe.",
						"options":{
							"leave":"exit",
						}
					},
					{
						"state":"mid_trust_penalty_nameless",
						"trust_required":3,
						"text":"You're still alive. That's good.",
						"options":{
							"How are you?":"talk_penalty_nameless",
							"leave":"exit"
						}
					},
					{
						"state":"talk_penalty_nameless",
						"text":"... Still alive.",
						"options":{
							"Need something?":"idk_penalty",
							"leave":"exit"
						}
					}
				]
			},
		],
	}
